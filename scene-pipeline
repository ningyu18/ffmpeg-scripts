#!/bin/sh

#===============================================================================
# scene-pipeline
# detect scenes in a local video or YouTube video, cut into clips or images,
# and package the results into a zip file
#===============================================================================

# dependencies:
# ffmpeg, scene-detect, scene-time, yt-dlp, zip

# prepend this script's directory to PATH so sibling scripts are always found
PATH="$(cd "$(dirname "$0")" && pwd):${PATH}"

#===============================================================================
# script usage
#===============================================================================

usage () {
[ -z "${1}" ] || echo "! ${1}"
echo "\
$(basename "$0") -i input -t threshold [-m video|image] [-p pad] [-j jobs] [-o output.zip]

-i  input.(mp4|mov|mkv|m4v) or YouTube video ID
-t  threshold 0.1-0.9
-m  video (default) or image
-p  silence pad in seconds appended to each video clip (default: 0, video mode only)
-j  max parallel ffmpeg jobs (default: number of cpu cores)
-o  output.zip (default: inputname-scenes-YYYY-MM-DD-HH-MM-SS.zip)"
exit 2
}


#===============================================================================
# error messages
#===============================================================================

INVALID_OPT_ERR='Invalid option:'
REQ_ARG_ERR='requires an argument'
WRONG_ARGS_ERR='wrong number of arguments passed to script'


#===============================================================================
# check the number of arguments passed to the script
#===============================================================================

[ $# -gt 0 ] || usage "${WRONG_ARGS_ERR}"


#===============================================================================
# getopts check the options passed to the script
#===============================================================================

while getopts ':i:t:m:p:j:o:h' opt
do
  case ${opt} in
     i) input="${OPTARG}";;
     t) threshold="${OPTARG}";;
     m) mode="${OPTARG}";;
     p) pad="${OPTARG}";;
     j) max_jobs="${OPTARG}";;
     o) output_zip="${OPTARG}";;
     h) usage;;
     \?) usage "${INVALID_OPT_ERR} ${OPTARG}" 1>&2;;
     :) usage "${INVALID_OPT_ERR} ${OPTARG} ${REQ_ARG_ERR}" 1>&2;;
  esac
done
shift $((OPTIND-1))


#===============================================================================
# validate arguments
#===============================================================================

[ -z "${input}" ] && usage "input required"
[ -z "${threshold}" ] && usage "threshold required"

mode="${mode:-video}"

case "${mode}" in
  video|image) ;;
  *) usage "mode must be 'video' or 'image'";;
esac

pad="${pad:-0}"
max_jobs="${max_jobs:-1}"


#===============================================================================
# throttle: run background jobs up to max_jobs at a time
# call after launching each background job
#===============================================================================

jobs_running=0

throttle () {
  jobs_running=$((jobs_running + 1))
  if [ "${jobs_running}" -ge "${max_jobs}" ]; then
    wait
    jobs_running=0
  fi
}


#===============================================================================
# step 1: download youtube video if input is not an existing file
#===============================================================================

if [ ! -f "${input}" ]; then
  echo "Input file not found, treating as YouTube video ID: ${input}"
  yt-dlp \
    -f 'bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best' \
    "https://www.youtube.com/watch?v=${input}" \
    -o "${input}.mp4"
  input="${input}.mp4"
fi


#===============================================================================
# variables
#===============================================================================

input_nopath="${input##*/}"
input_name="${input_nopath%.*}"
timestamp=$(date +%Y-%m-%d-%H-%M-%S)
output_zip="${output_zip:-${input_name}-scenes-${timestamp}.zip}"


#===============================================================================
# cleanup temp files on exit
#===============================================================================

detect_file=$(mktemp /tmp/scene-pipeline-detect-XXXXXX.txt)
cutfile=$(mktemp /tmp/scene-pipeline-cutlist-XXXXXX.txt)

cleanup () {
  rm -f "${detect_file}" "${cutfile}"
}
trap cleanup EXIT


#===============================================================================
# step 2: scene detection
#===============================================================================

echo "Detecting scenes in ${input} with threshold ${threshold}..."
scene-detect -i "${input}" -t "${threshold}" -o "${detect_file}"


#===============================================================================
# step 3 and 4: process based on mode
#===============================================================================

if [ "${mode}" = "video" ]; then

  # step 3: convert timecodes to cut ranges
  echo "Converting timecodes to cut ranges..."
  scene-time -i "${detect_file}" -o "${cutfile}"

  # step 4a: cut video clips in parallel
  echo "Cutting video clips with up to ${max_jobs} parallel jobs..."
  count=1
  while IFS=, read -r start duration; do
    elapsed=$(printf '%s\n' "${duration}" | awk -F: '{
      split($3, sec, ".")
      print int($1 * 3600 + $2 * 60 + sec[1])
    }')
    if [ "${elapsed}" -gt 1 ]; then
      output=$(printf "${input_name}-%04d.mp4" "${count}")
      count=$((count + 1))
      (
        ffmpeg \
          -nostdin \
          -hide_banner \
          -stats -v panic \
          -ss "${start}" \
          -i "${input}" \
          -t "${duration}" \
          -c:a aac \
          -c:v libx264 -profile:v high \
          -pix_fmt yuv420p -movflags +faststart \
          -f mp4 \
          "${output}"
      ) &
      throttle
    else
      echo "skipping ${start}, ${duration}"
    fi
  done < "${cutfile}"
  wait
  jobs_running=0

  # add silence padding in parallel if requested
  if [ "${pad}" != "0" ]; then
    echo "Adding ${pad}s silence pad with up to ${max_jobs} parallel jobs..."
    for clip in "${input_name}"-[0-9][0-9][0-9][0-9].mp4; do
      [ -f "${clip}" ] || continue
      (
        tmp="${clip%.mp4}-padded.mp4"
        ffmpeg \
          -nostdin \
          -hide_banner \
          -stats -v panic \
          -i "${clip}" \
          -vf "tpad=stop_mode=clone:stop_duration=${pad}" \
          -af "apad=pad_dur=${pad}" \
          -c:v libx264 -profile:v high \
          -pix_fmt yuv420p -movflags +faststart \
          -c:a aac \
          "${tmp}" && mv "${tmp}" "${clip}"
      ) &
      throttle
    done
    wait
    jobs_running=0
  fi

  # step 5: zip video clips
  echo "Creating zip archive ${output_zip}..."
  zip "${output_zip}" "${input_name}"-[0-9][0-9][0-9][0-9].mp4

else

  # step 4b: extract images at scene timecodes in parallel
  echo "Extracting scene images with up to ${max_jobs} parallel jobs..."
  while IFS= read -r seconds; do
    (
      output="${input_name}-[${seconds}].png"
      ffmpeg \
        -nostdin \
        -hide_banner \
        -stats -v panic \
        -ss "${seconds}" \
        -i "${input}" \
        -q:v 2 -f image2 \
        -vframes 1 \
        "${output}"
    ) &
    throttle
  done < "${detect_file}"
  wait
  jobs_running=0

  # step 5: zip images (filenames contain brackets so use find + pipe)
  echo "Creating zip archive ${output_zip}..."
  find . -maxdepth 1 -name "${input_name}-*.png" | zip "${output_zip}" -@

fi

echo "Done: ${output_zip}"
